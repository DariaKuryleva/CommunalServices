<Window x:Class="CommunalServicesApp.Windows.ReportEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommunalServicesApp.Windows"
        mc:Ignorable="d"
        Title='МУП "Юго-Запад"'
        WindowStartupLocation="CenterScreen"
        MinHeight="400"
        MinWidth="500"
        Height="400"
        Width="500">
    <Grid>
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400">
            <TextBlock Text="Добавление"
                       Name="TitleTextBlock"
                       FontSize="18"
                       TextAlignment="Center"/>
            
            <TextBlock Text="Тип услуги"/>
            <ComboBox Name="ServiceTypesComboBox"/>

            <TextBlock Text="Название заявки"/>
            <TextBox Name="TitleTextBox"/>

            <TextBlock Text="Описание заявки"/>
            <TextBox Name="NoteTextBox"/>

            <TextBlock Text="Клиент"/>
            <ComboBox Name="ClientsComboBox"/>

            <TextBlock Text="Дата заявки (сегодняшяя)"/>
            <TextBox Name="DatetimeTextBox"/>

            <TextBlock Text="Статус"/>
            <ComboBox Name="StatusesComboBox"/>

            <TextBlock Text="Айди сотрудника"/>
            <ComboBox Name="WorkersComboBox"/>

            <TextBlock Text="Приоритет"/>
            <ComboBox Name="PrioritiesComboBox"/>

            <Button Content="Добавить"
                    Name="AddButton"
                    Margin="0 20 0 0"
                    Click="AddButtonClick"/>
            <Button Content="Редактировать"
                    Visibility="Collapsed"
                    Name="EditButton"
                    Margin="0 20 0 0"
                    Click="EditButtonClick"/>

        </StackPanel>
    </Grid>
</Window>
