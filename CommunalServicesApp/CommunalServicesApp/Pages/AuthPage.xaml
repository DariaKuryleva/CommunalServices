<Page x:Class="CommunalServicesApp.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CommunalServicesApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600"
      d:DesignWidth="1000"
      Title="AuthPage">
    <Grid>
        <StackPanel Orientation="Vertical"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            
            <TextBlock Text="Авторизация"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="24"/>

            <StackPanel Orientation="Horizontal" Width="300" Margin="0 40 0 0">
                <Image Source="/Images/icons2.png" Width="20" Height="20" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <TextBlock Text="Логин:" FontSize="20" VerticalAlignment="Center"/>

            </StackPanel>
            <TextBox Name="LoginTextBox" Height="30" Width="300" Margin="0 5 0 0"   
                     Background="Transparent"
                     BorderBrush="Black"
                     BorderThickness="0,0,0,1"
                     Foreground="Black"
                     FontSize="14"/>

            <StackPanel Orientation="Horizontal" Width="300" Margin="0 40 0 0">
                <Image Source="/Images/icons3.png" Width="20" Height="20" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <TextBlock Text="Пароль:" FontSize="20" HorizontalAlignment="Center" />

            </StackPanel>
            <TextBox Name="PasswordTextBox" Height="30" Width="300" Margin="0 5 0 0" 
                     Background="Transparent"
                     BorderBrush="Black"
                     BorderThickness="0,0,0,1"
                     Foreground="Black"
                     FontSize="14"/>

            <Button Content="Войти"
                    Height="30"
                    Width="150"
                    FontSize="18"
                    Margin="0 50 0 0"
                    Background="DarkCyan "
                    Click="LoginButtonClick"/>
        </StackPanel>
    </Grid>
</Page>
